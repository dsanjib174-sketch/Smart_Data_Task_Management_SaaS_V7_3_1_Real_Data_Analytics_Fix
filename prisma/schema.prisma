generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  EXPIRED
}

enum RoleScope {
  SMART_DATA
  CLIENT
}

enum TaskStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  WAITING_APPROVAL
  COMPLETED
  CLOSED
  CANCELLED
}

enum InternalTaskStatus {
  NEW
  ASSIGNED
  IN_PROGRESS
  TESTING
  WAITING_APPROVAL
  COMPLETED
  CLOSED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ComplaintStatus {
  NEW
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum InvoiceStatus {
  DRAFT
  GENERATED
  PAID
  CANCELLED
  OVERDUE
}

enum MaintenanceStatus {
  SCHEDULED
  DUE
  OVERDUE
  COMPLETED
  CANCELLED
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
}

enum ScheduleType {
  SMART_DATA
  CLIENT
}

model CompanySetting {
  id          String   @id @default("SMART_DATA")
  companyName String   @default("Smart Data")
  legalName   String?
  gstNumber   String?
  panNumber   String?
  address     String?
  city        String?
  state       String?
  pincode     String?
  country     String?  @default("India")
  email       String?
  phone       String?
  website     String?
  bankName    String?
  accountName String?
  accountNo   String?
  ifscCode    String?
  upiId       String?
  logoUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Tenant {
  id             String       @id @default(uuid())
  companyName    String
  contactName    String?
  email          String       @unique
  phone          String?
  gstNumber      String?
  panNumber      String?
  billingAddress String?
  city           String?
  state          String?
  pincode        String?
  status         TenantStatus @default(TRIAL)
  planId         String?

  plan           SubscriptionPlan? @relation(fields: [planId], references: [id])
  users          User[]
  locations      Location[]
  tasks          Task[]
  complaints     Complaint[]
  invoices       SubscriptionInvoice[]
  maintenance    PreventiveMaintenance[]
  loginHistories LoginHistory[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SubscriptionPlan {
  id           String   @id @default(uuid())
  name         String   @unique
  price        Decimal  @default(0)
  durationDays Int      @default(30)
  maxUsers     Int      @default(5)
  maxTasks     Int      @default(100)
  isActive     Boolean  @default(true)

  tenants      Tenant[]
  invoices     SubscriptionInvoice[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Role {
  id          String    @id @default(uuid())
  name        String
  scope       RoleScope
  permissions Json      @default("{}")
  users       User[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([name, scope])
}

model User {
  id                  String     @id @default(uuid())
  tenantId            String?
  name                String
  username            String?    @unique
  employeeCode        String?
  email               String     @unique
  password            String
  phone               String?
  designation         String?
  department          String?
  roleId              String?
  reportingManagerId  String?
  escalationManagerId String?
  status              UserStatus @default(ACTIVE)

  tenant              Tenant? @relation(fields: [tenantId], references: [id])
  role                Role?   @relation(fields: [roleId], references: [id])
  reportingManager    User?   @relation("ReportingHierarchy", fields: [reportingManagerId], references: [id])
  reportees           User[]  @relation("ReportingHierarchy")
  escalationManager   User?   @relation("EscalationHierarchy", fields: [escalationManagerId], references: [id])
  escalationReportees User[]  @relation("EscalationHierarchy")

  createdTasks  Task[] @relation("TaskCreatedBy")
  assignedTasks Task[] @relation("TaskAssignedTo")
  internalCreatedTasks InternalTask[] @relation("InternalTaskCreatedBy")
  internalAssignedTasks InternalTask[] @relation("InternalTaskAssignedTo")
  comments      Comment[]
  attachments   Attachment[]
  notifications Notification[]
  assignedMaintenance PreventiveMaintenance[] @relation("MaintenanceAssignedTo")
  refreshTokens RefreshToken[]
  loginHistories LoginHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([reportingManagerId])
  @@index([escalationManagerId])
}

model Location {
  id           String @id @default(uuid())
  tenantId     String
  floorName    String
  locationName String
  department   String?
  qrCode       String?
  complaintUrl String?
  status       String @default("ACTIVE")

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  complaints  Complaint[]
  tasks       Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id           String     @id @default(uuid())
  tenantId     String
  locationId   String?
  title        String
  description  String?
  status       TaskStatus @default(OPEN)
  priority     Priority   @default(MEDIUM)
  dueDate      DateTime?
  createdById  String?
  assignedToId String?

  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  location    Location? @relation(fields: [locationId], references: [id])
  createdBy   User?     @relation("TaskCreatedBy", fields: [createdById], references: [id])
  assignedTo  User?     @relation("TaskAssignedTo", fields: [assignedToId], references: [id])
  comments    Comment[]
  attachments Attachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Complaint {
  id          String          @id @default(uuid())
  tenantId    String
  locationId  String?
  subject     String
  description String?
  status      ComplaintStatus @default(NEW)
  priority    Priority        @default(MEDIUM)
  reporterName  String?
  reporterPhone String?
  photoUrl      String?
  audioUrl      String?
  videoUrl      String?

  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  location    Location? @relation(fields: [locationId], references: [id])
  comments    Comment[]
  attachments Attachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Comment {
  id          String @id @default(uuid())
  taskId      String?
  complaintId String?
  userId      String?
  message     String

  task        Task?      @relation(fields: [taskId], references: [id])
  complaint   Complaint? @relation(fields: [complaintId], references: [id])
  user        User?      @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attachment {
  id           String @id @default(uuid())
  taskId       String?
  complaintId  String?
  uploadedById String?
  fileName     String
  fileUrl      String
  fileType     String?
  fileSize     Int?

  task        Task?      @relation(fields: [taskId], references: [id])
  complaint   Complaint? @relation(fields: [complaintId], references: [id])
  uploadedBy  User?      @relation(fields: [uploadedById], references: [id])

  createdAt DateTime @default(now())
}

model Notification {
  id        String  @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean @default(false)

  user      User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model SubscriptionInvoice {
  id          String        @id @default(uuid())
  tenantId    String
  planId      String?
  invoiceNo   String        @unique
  amount      Decimal       @default(0)
  gstRate     Decimal       @default(18)
  gstAmount   Decimal       @default(0)
  totalAmount Decimal       @default(0)
  status      InvoiceStatus @default(GENERATED)
  invoiceDate DateTime      @default(now())
  dueDate     DateTime?
  notes       String?

  tenant      Tenant @relation(fields: [tenantId], references: [id])
  plan        SubscriptionPlan? @relation(fields: [planId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InternalTask {
  id            String             @id @default(uuid())
  title         String
  description   String?
  department    String?
  priority      Priority           @default(MEDIUM)
  status        InternalTaskStatus @default(NEW)
  startDate     DateTime?
  dueDate       DateTime?
  completedAt   DateTime?
  attachmentUrl String?
  checklist     Json?
  createdById   String?
  assignedToId  String?

  createdBy    User? @relation("InternalTaskCreatedBy", fields: [createdById], references: [id])
  assignedTo   User? @relation("InternalTaskAssignedTo", fields: [assignedToId], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PreventiveMaintenance {
  id              String @id @default(uuid())
  scheduleType    ScheduleType @default(SMART_DATA)
  tenantId        String?
  title           String
  category        String?
  description     String?
  scheduledDate   DateTime
  completedDate   DateTime?
  assignedToId    String?
  serviceArea     String?
  vendorName      String?
  frequency       String?
  reminderDays    Int @default(7)
  escalation      Boolean @default(false)
  status          MaintenanceStatus @default(SCHEDULED)
  escalationLevel Int @default(0)
  remarks         String?

  tenant          Tenant? @relation(fields: [tenantId], references: [id])
  assignedTo      User?  @relation("MaintenanceAssignedTo", fields: [assignedToId], references: [id])
  reminders       EmailReminder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailReminder {
  id              String @id @default(uuid())
  tenantId        String?
  maintenanceId   String?
  reminderType    String @default("MAINTENANCE")
  recipientEmail  String
  subject         String
  body            String
  scheduledAt     DateTime
  sentAt          DateTime?
  status          ReminderStatus @default(PENDING)

  maintenance     PreventiveMaintenance? @relation(fields: [maintenanceId], references: [id])

  createdAt DateTime @default(now())
}

model EscalationRule {
  id          String @id @default(uuid())
  tenantId    String?
  module      String
  level       Int @default(1)
  delayHours  Int @default(24)
  notifyEmail String
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RefreshToken {
  id          String @id @default(uuid())
  userId      String
  tokenHash   String
  expiresAt   DateTime
  revokedAt   DateTime?
  userAgent   String?
  ipAddress   String?

  user        User @relation(fields: [userId], references: [id])

  createdAt   DateTime @default(now())
}

model LoginHistory {
  id          String @id @default(uuid())
  userId      String?
  tenantId    String?
  email       String
  status      String
  ipAddress   String?
  userAgent   String?
  message     String?

  user        User? @relation(fields: [userId], references: [id])
  tenant      Tenant? @relation(fields: [tenantId], references: [id])

  createdAt   DateTime @default(now())
}

model PasswordPolicy {
  id          String @id @default("DEFAULT")
  minLength   Int @default(8)
  requireUppercase Boolean @default(true)
  requireLowercase Boolean @default(true)
  requireNumber Boolean @default(true)
  requireSpecial Boolean @default(false)
  expiryDays  Int @default(90)
  maxFailedAttempts Int @default(5)
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id          String @id @default(uuid())
  tenantId    String?
  userId      String?
  action      String
  module      String
  recordId    String?
  details     Json?
  createdAt   DateTime @default(now())
}
