<%- include('../partials/header') %>

<h2>QR Floor & Location Master</h2>

<% if (smartDataUser) { %>
<form method="GET" action="/qr-locations" class="card p-3 mb-3">
  <div class="row g-3 align-items-end">
    <div class="col-md-4">
      <label class="form-label">QR Scope</label>
      <select name="scope" class="form-select" onchange="this.form.submit()">
        <option value="SMART_DATA" <%= selectedScope === 'SMART_DATA' ? 'selected' : '' %>>Smart Data Internal</option>
        <option value="CLIENT" <%= selectedScope === 'CLIENT' ? 'selected' : '' %>>Client</option>
      </select>
    </div>

    <% if (selectedScope === 'CLIENT') { %>
    <div class="col-md-4">
      <label class="form-label">Filter Client</label>
      <select name="tenantId" class="form-select" onchange="this.form.submit()">
        <option value="">Select Client</option>
        <% tenants.forEach(t => { %>
          <option value="<%= t.id %>" <%= selectedTenantId === t.id ? 'selected' : '' %>><%= t.companyName %></option>
        <% }) %>
      </select>
    </div>
    <% } %>
  </div>
</form>
<% } %>

<form method="POST" action="/qr-locations/create" class="card p-3 mb-4">
  <div class="row g-3 align-items-end">
    <% if (smartDataUser) { %>
    <div class="col-md-3">
      <label class="form-label">QR Scope</label>
      <select id="qrScope" name="scope" class="form-select" onchange="toggleClientField()">
        <option value="SMART_DATA" <%= selectedScope === 'SMART_DATA' ? 'selected' : '' %>>Smart Data Internal</option>
        <option value="CLIENT" <%= selectedScope === 'CLIENT' ? 'selected' : '' %>>Client</option>
      </select>
    </div>

    <div id="clientField" class="col-md-3">
      <label class="form-label">Client</label>
      <select id="tenantId" name="tenantId" class="form-select">
        <option value="">Select Client</option>
        <% tenants.forEach(t => { %>
          <option value="<%= t.id %>" <%= selectedTenantId === t.id ? 'selected' : '' %>><%= t.companyName %></option>
        <% }) %>
      </select>
    </div>
    <% } else { %>
      <input type="hidden" name="scope" value="CLIENT">
    <% } %>

    <div class="col-md-2">
      <label class="form-label">Floor</label>
      <input name="floorName" class="form-control" placeholder="8th Floor" required>
    </div>

    <div class="col-md-2">
      <label class="form-label">Location</label>
      <input name="locationName" class="form-control" placeholder="Washroom / Pantry" required>
    </div>

    <div class="col-md-2">
      <label class="form-label">Department</label>
      <input name="department" class="form-control" placeholder="Admin / HK">
    </div>

    <div class="col-md-1">
      <button class="btn btn-primary w-100">Create</button>
    </div>
  </div>
</form>

<table class="table table-bordered align-middle">
  <thead>
    <tr>
      <th>Scope</th>
      <th>Client</th>
      <th>Floor</th>
      <th>Location</th>
      <th>Department</th>
      <th>QR</th>
      <th>Public Link</th>
    </tr>
  </thead>
  <tbody>
    <% if (!locations.length) { %>
      <tr><td colspan="7" class="text-center text-muted">No QR locations created.</td></tr>
    <% } %>

    <% locations.forEach(l => { %>
      <tr>
        <td><%= l.scope === 'SMART_DATA' ? 'Smart Data Internal' : 'Client' %></td>
        <td><%= l.tenant ? l.tenant.companyName : 'Smart Data' %></td>
        <td><%= l.floorName %></td>
        <td><%= l.locationName %></td>
        <td><%= l.department || '' %></td>
        <td>
          <% if (l.qrCode) { %>
            <img src="<%= l.qrCode %>" width="90" alt="QR Code"><br>
            <a href="<%= l.qrCode %>" download="QR_<%= l.scope %>_<%= l.floorName %>_<%= l.locationName %>.png">Download</a>
          <% } %>
        </td>
        <td><a href="<%= l.complaintUrl %>" target="_blank">Open</a></td>
      </tr>
    <% }) %>
  </tbody>
</table>

<% if (smartDataUser) { %>
<script>
  function toggleClientField() {
    const scope = document.getElementById('qrScope').value;
    const wrapper = document.getElementById('clientField');
    const tenant = document.getElementById('tenantId');
    const clientMode = scope === 'CLIENT';
    wrapper.style.display = clientMode ? '' : 'none';
    tenant.required = clientMode;
    if (!clientMode) tenant.value = '';
  }
  toggleClientField();
</script>
<% } %>

<%- include('../partials/footer') %>
