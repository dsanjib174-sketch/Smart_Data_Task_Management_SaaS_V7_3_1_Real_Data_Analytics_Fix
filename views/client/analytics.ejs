<%- include('../partials/header') %>
<div class="d-flex flex-wrap justify-content-between align-items-center mb-3"><div><h2>SLA, KPI & Escalation Analytics</h2><small class="text-muted"><%= allCompany?'Company-wide report':'Your team / personal visibility' %></small></div><div><a class="btn btn-outline-success" href="/client/analytics/report.csv">Export CSV/Excel</a> <a class="btn btn-outline-dark" target="_blank" href="/client/analytics/print">Presentation / PDF View</a></div></div>
<div class="row g-3 mb-4"><% Object.entries(data.kpis).forEach(([k,v])=>{ %><div class="col-6 col-md-3"><div class="card shadow-sm"><div class="card-body"><small class="text-muted"><%= k.replace(/([A-Z])/g,' $1') %></small><h3><%= k==='slaCompliance'?v+'%':v %></h3></div></div></div><% }) %></div>
<div class="row g-3"><div class="col-lg-6"><div class="card"><div class="card-header"><strong>Task Status</strong></div><div class="card-body"><canvas id="statusChart"></canvas></div></div></div><div class="col-lg-6"><div class="card"><div class="card-header"><strong>Task Priority</strong></div><div class="card-body"><canvas id="priorityChart"></canvas></div></div></div><div class="col-lg-6"><div class="card"><div class="card-header"><strong>Complaints by Floor</strong></div><div class="card-body"><canvas id="floorChart"></canvas></div></div></div><div class="col-lg-6"><div class="card"><div class="card-header"><strong>Department Performance</strong></div><div class="card-body"><canvas id="deptChart"></canvas></div></div></div></div>
<div class="card mt-4"><div class="card-header"><strong>Employee KPI & Escalation Report</strong></div><div class="table-responsive"><table class="table table-striped mb-0"><thead><tr><th>Employee</th><th>Department</th><th>Assigned</th><th>Completed</th><th>Pending</th><th>Overdue</th><th>Productivity</th></tr></thead><tbody><% data.employee.forEach(e=>{ %><tr><td><%= e.name %></td><td><%= e.department %></td><td><%= e.assigned %></td><td><%= e.completed %></td><td><%= e.pending %></td><td><%= e.overdue %></td><td><%= e.productivity %>%</td></tr><% }) %></tbody></table></div></div>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script><script>function chart(id,type,obj){new Chart(document.getElementById(id),{type,data:{labels:Object.keys(obj),datasets:[{label:'Count',data:Object.values(obj)}]},options:{responsive:true,plugins:{legend:{display:type==='doughnut'}}}})}chart('statusChart','doughnut',<%- JSON.stringify(data.taskStatus) %>);chart('priorityChart','bar',<%- JSON.stringify(data.taskPriority) %>);chart('floorChart','bar',<%- JSON.stringify(data.complaintFloor) %>);chart('deptChart','bar',<%- JSON.stringify(data.taskDepartment) %>);</script>
<%- include('../partials/footer') %>
