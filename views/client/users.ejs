<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-3"><div><h2>Employee User Management</h2><div class="text-muted">Active users: <%= users.filter(u=>u.status==='ACTIVE').length %> / <%= maxUsers %> allowed under <%= tenant.plan?.name||'Trial/Free' %> plan</div></div></div>
<% if(error){%><div class="alert alert-danger"><%= error %></div><%}%><% if(success){%><div class="alert alert-success"><%= success %></div><%}%>
<div class="card mb-4"><div class="card-header"><strong>Create Employee Login Credential</strong></div><div class="card-body"><form method="post" action="/client/users/create"><div class="row g-2">
<div class="col-md-3"><input class="form-control" name="name" placeholder="Employee Name" required></div><div class="col-md-2"><input class="form-control" name="employeeCode" placeholder="Employee Code"></div><div class="col-md-3"><input class="form-control" name="username" placeholder="User ID"></div><div class="col-md-4"><input class="form-control" type="email" name="email" placeholder="Official Email" required></div>
<div class="col-md-3"><input class="form-control" name="password" placeholder="Password (default User@12345)"></div><div class="col-md-2"><input class="form-control" name="phone" placeholder="Mobile"></div><div class="col-md-2"><input class="form-control" name="department" placeholder="Department"></div><div class="col-md-2"><input class="form-control" name="designation" placeholder="Designation"></div>
<div class="col-md-3"><select class="form-select" name="roleId" required><option value="">Select Role</option><% roles.forEach(r=>{ %><option value="<%= r.id %>"><%= r.name %></option><% }) %></select></div>
<div class="col-md-3"><select class="form-select" name="reportingManagerId"><option value="">Reporting Manager</option><% users.filter(u=>u.status==='ACTIVE').forEach(u=>{ %><option value="<%= u.id %>"><%= u.name %></option><% }) %></select></div>
<div class="col-md-3"><select class="form-select" name="escalationManagerId"><option value="">Escalation Manager</option><% users.filter(u=>u.status==='ACTIVE').forEach(u=>{ %><option value="<%= u.id %>"><%= u.name %></option><% }) %></select></div>
<div class="col-md-2"><select class="form-select" name="status"><option>ACTIVE</option><option>INACTIVE</option></select></div><div class="col-md-2"><button class="btn btn-primary w-100">Create User</button></div>
</div></form></div></div>
<div class="row g-3"><% ['CLIENT_ADMIN','MANAGER','EMPLOYEE','VIEWER'].forEach(role=>{ %><div class="col-md-6 col-xl-3"><div class="card h-100"><div class="card-header"><strong><%= role.replace('_',' ') %></strong> <span class="badge bg-dark"><%= users.filter(u=>u.role?.name===role).length %></span></div><div class="card-body bg-light" style="min-height:260px"><% users.filter(u=>u.role?.name===role).forEach(u=>{ %><div class="card mb-2 shadow-sm"><div class="card-body p-3"><strong><%= u.name %></strong><br><small><%= u.username||u.email %></small><div class="small text-muted"><%= u.department||'-' %> | <%= u.designation||'-' %></div><div class="small">Reports to: <%= u.reportingManager?.name||'-' %></div><div class="small">Escalates to: <%= u.escalationManager?.name||'-' %></div><span class="badge <%= u.status==='ACTIVE'?'bg-success':'bg-secondary' %>"><%= u.status %></span><details class="mt-2"><summary class="small">Edit Access</summary><form method="post" action="/client/users/<%= u.id %>/update" class="mt-2"><select class="form-select form-select-sm mb-1" name="roleId"><% roles.forEach(r=>{ %><option value="<%= r.id %>" <%= u.roleId===r.id?'selected':'' %>><%= r.name %></option><% }) %></select><input class="form-control form-control-sm mb-1" name="department" value="<%= u.department||'' %>" placeholder="Department"><input class="form-control form-control-sm mb-1" name="designation" value="<%= u.designation||'' %>" placeholder="Designation"><select class="form-select form-select-sm mb-1" name="reportingManagerId"><option value="">No Reporting Manager</option><% users.filter(m=>m.id!==u.id).forEach(m=>{ %><option value="<%= m.id %>" <%= u.reportingManagerId===m.id?'selected':'' %>><%= m.name %></option><% }) %></select><select class="form-select form-select-sm mb-1" name="escalationManagerId"><option value="">No Escalation Manager</option><% users.filter(m=>m.id!==u.id).forEach(m=>{ %><option value="<%= m.id %>" <%= u.escalationManagerId===m.id?'selected':'' %>><%= m.name %></option><% }) %></select><select class="form-select form-select-sm mb-1" name="status"><option <%= u.status==='ACTIVE'?'selected':'' %>>ACTIVE</option><option <%= u.status==='INACTIVE'?'selected':'' %>>INACTIVE</option></select><input class="form-control form-control-sm mb-1" name="password" placeholder="New password (optional)"><button class="btn btn-sm btn-outline-primary w-100">Update</button></form></details></div></div><% }) %></div></div></div><% }) %></div>
<%- include('../partials/footer') %>
