<!doctype html><html><head><meta charset="utf-8"><title><%= title %></title><style>body{font-family:Arial;margin:30px;color:#222}h1,h2{margin-bottom:5px}.kpis{display:flex;gap:12px;flex-wrap:wrap}.kpi{border:1px solid #bbb;padding:12px;min-width:130px}table{border-collapse:collapse;width:100%;margin-top:20px}th,td{border:1px solid #bbb;padding:7px;text-align:left}@media print{button{display:none}}</style></head><body><button onclick="window.print()">Print / Save PDF</button><h1><%= tenant.companyName %></h1><h2>SLA & KPI Report</h2><p>Generated: <%= new Date().toLocaleString('en-IN') %></p><div class="kpis"><% Object.entries(kpis).forEach(([k,v])=>{ %><div class="kpi"><small><%= k %></small><h2><%= k==='slaCompliance'?v+'%':v %></h2></div><% }) %></div><table><thead><tr><th>Task</th><th>Status</th><th>Priority</th><th>Assigned To</th><th>Department</th><th>Due Date</th></tr></thead><tbody><% tasks.forEach(t=>{ %><tr><td><%= t.title %></td><td><%= t.status %></td><td><%= t.priority %></td><td><%= t.assignedTo?.name||'-' %></td><td><%= t.assignedTo?.department||t.location?.department||'-' %></td><td><%= t.dueDate?new Date(t.dueDate).toLocaleDateString('en-IN'):'-' %></td></tr><% }) %></tbody></table></body></html>