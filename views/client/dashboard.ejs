<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-3"><div><h2 class="mb-0"><%= currentUser.tenant.companyName %> Dashboard</h2><small class="text-muted"><%= currentUser.role.name %> access</small></div><a href="/tasks" class="btn btn-primary">Open Task Kanban</a></div>
<div class="row g-3 mb-4">
<% const cards=[['Total Tasks',stats.totalTasks],['Open Tasks',stats.openTasks],['In Progress',stats.inProgress],['Completed',stats.completed],['Overdue',stats.overdue],['Due Today',stats.todayTasks],['Open Complaints',stats.openComplaints],['SLA Compliance',stats.slaCompliance+'%'],['Active Users',stats.users],['QR Locations',stats.locations],['Upcoming PM',stats.pmUpcoming]]; %>
<% cards.forEach(c=>{ %><div class="col-6 col-md-3 col-xl-2"><div class="card h-100 shadow-sm"><div class="card-body"><small class="text-muted"><%= c[0] %></small><h3 class="mb-0"><%= c[1] %></h3></div></div></div><% }) %>
</div>
<div class="card"><div class="card-header d-flex justify-content-between"><strong>Recent Tasks</strong><a href="/client/analytics">View SLA & KPI Analytics</a></div><div class="table-responsive"><table class="table table-hover mb-0"><thead><tr><th>Task</th><th>Status</th><th>Priority</th><th>Assigned To</th><th>Location</th><th>Due Date</th></tr></thead><tbody><% recentTasks.forEach(t=>{ %><tr><td><%= t.title %></td><td><span class="badge bg-secondary"><%= t.status %></span></td><td><%= t.priority %></td><td><%= t.assignedTo?.name||'Unassigned' %></td><td><%= t.location ? `${t.location.floorName} - ${t.location.locationName}` : '-' %></td><td><%= t.dueDate ? new Date(t.dueDate).toLocaleDateString('en-IN') : '-' %></td></tr><% }) %><% if(!recentTasks.length){%><tr><td colspan="6" class="text-center text-muted py-4">No tasks available.</td></tr><%}%></tbody></table></div></div>
<%- include('../partials/footer') %>
