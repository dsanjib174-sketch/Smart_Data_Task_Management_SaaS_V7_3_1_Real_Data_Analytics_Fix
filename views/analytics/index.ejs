<%- include('../partials/header', { title }) %>
<style>
  .bi-hero{background:linear-gradient(135deg,#121826,#273755);color:#fff;border-radius:18px;padding:22px;margin-bottom:18px}
  .kpi-card{border:0;border-radius:16px;box-shadow:0 5px 18px rgba(0,0,0,.08);height:100%}
  .kpi-value{font-size:1.65rem;font-weight:800}.kpi-label{color:#667085;font-size:.85rem}
  .chart-card{border:0;border-radius:16px;box-shadow:0 5px 18px rgba(0,0,0,.08);margin-bottom:18px}.chart-box{height:340px}
  .filter-card{border-radius:16px}.section-title{font-weight:800;margin:26px 0 14px}.dark-mode{background:#101828;color:#eef2ff}.dark-mode .card,.dark-mode .table{background:#182230;color:#eef2ff}.dark-mode .kpi-label{color:#b4c2d9}
  .fullscreen-dashboard{position:fixed!important;z-index:9999;inset:0;overflow:auto;background:#f3f6fb;padding:20px}
</style>
<div id="analyticsPage">
  <div class="bi-hero d-flex flex-wrap justify-content-between align-items-center">
    <div><h2 class="mb-1">Enterprise Analytics Center</h2><div>Power BI style executive reporting, cross-filtering, drill-down and export center.</div></div>
    <div class="mt-3 mt-md-0">
      <a class="btn btn-light btn-sm" href="/analytics/report.csv?<%= new URLSearchParams(data.filters).toString() %>">CSV Download</a>
      <a class="btn btn-warning btn-sm" href="/analytics/print?<%= new URLSearchParams(data.filters).toString() %>" target="_blank">PDF / Print</a>
      <button class="btn btn-outline-light btn-sm" onclick="toggleDarkMode()">Dark Mode</button>
      <button class="btn btn-outline-light btn-sm" onclick="toggleFullScreen()">Full Screen</button>
    </div>
  </div>

  <form class="card filter-card p-3 mb-3" method="GET" action="/analytics">
    <div class="row g-2">
      <div class="col-md-2"><label>Date From</label><input class="form-control" type="date" name="startDate" value="<%= data.filters.start.toISOString().slice(0,10) %>"></div>
      <div class="col-md-2"><label>Date To</label><input class="form-control" type="date" name="endDate" value="<%= data.filters.end.toISOString().slice(0,10) %>"></div>
      <div class="col-md-2"><label>Client</label><select class="form-select" name="clientId"><option value="">All Clients</option><% data.lists.tenants.forEach(t=>{ %><option value="<%= t.id %>" <%= data.filters.clientId===t.id?'selected':'' %>><%= t.companyName %></option><% }) %></select></div>
      <div class="col-md-2"><label>Plan</label><select class="form-select" name="planId"><option value="">All Plans</option><% data.lists.plans.forEach(p=>{ %><option value="<%= p.id %>" <%= data.filters.planId===p.id?'selected':'' %>><%= p.name %></option><% }) %></select></div>
      <div class="col-md-2"><label>Priority</label><select class="form-select" name="priority"><option value="">All Priority</option><% ['LOW','MEDIUM','HIGH','URGENT'].forEach(p=>{ %><option value="<%= p %>" <%= data.filters.priority===p?'selected':'' %>><%= p %></option><% }) %></select></div>
      <div class="col-md-2"><label>Status</label><select class="form-select" name="status"><option value="">All Status</option><% ['OPEN','ASSIGNED','IN_PROGRESS','WAITING_APPROVAL','COMPLETED','CLOSED','CANCELLED'].forEach(s=>{ %><option value="<%= s %>" <%= data.filters.status===s?'selected':'' %>><%= s %></option><% }) %></select></div>
      <div class="col-md-2"><label>City</label><select class="form-select" name="city"><option value="">All Cities</option><% data.lists.cities.forEach(c=>{ %><option value="<%= c %>" <%= data.filters.city===c?'selected':'' %>><%= c %></option><% }) %></select></div>
      <div class="col-md-2"><label>State</label><select class="form-select" name="state"><option value="">All States</option><% data.lists.states.forEach(s=>{ %><option value="<%= s %>" <%= data.filters.state===s?'selected':'' %>><%= s %></option><% }) %></select></div>
      <div class="col-md-2"><label>Sales Executive</label><select class="form-select" name="salesExecutive"><option value="">All Sales</option><% data.lists.users.filter(u=>u.role?.name==='SALES').forEach(u=>{ %><option value="<%= u.id %>"><%= u.name %></option><% }) %></select></div>
      <div class="col-md-2 d-flex align-items-end"><button class="btn btn-primary w-100">Apply Filters</button></div>
      <div class="col-md-2 d-flex align-items-end"><a class="btn btn-outline-secondary w-100" href="/analytics">Reset</a></div>
    </div>
  </form>

  <h4 class="section-title">Executive Dashboard</h4>
  <div class="row g-3">
    <% Object.entries({ 'Total Clients':data.kpis.totalClients,'Active Clients':data.kpis.activeClients,'Trial Clients':data.kpis.trialClients,'Expired Clients':data.kpis.expiredClients,'MRR':`₹${data.kpis.mrr}`,'ARR':`₹${data.kpis.arr}`,'Total Employees':data.kpis.totalEmployees,'Active Users':data.kpis.activeUsers,"Today's Tasks":data.kpis.todaysTasks,'Overdue Tasks':data.kpis.overdueTasks,'Open Complaints':data.kpis.openComplaints,'SLA Compliance':`${data.kpis.slaCompliance}%`,'CSAT':`${data.kpis.csat}%`}).forEach(([label,value])=>{ %>
      <div class="col-6 col-md-3 col-xl-2"><div class="card kpi-card p-3"><div class="kpi-label"><%= label %></div><div class="kpi-value"><%= value %></div></div></div>
    <% }) %>
  </div>

  <h4 class="section-title">Sales Analytics</h4>
  <div class="row"><div class="col-lg-8"><div class="card chart-card p-3"><h6>Revenue by Month</h6><div id="revenueMonth" class="chart-box"></div></div></div><div class="col-lg-4"><div class="card chart-card p-3"><h6>Revenue by Plan</h6><div id="revenuePlan" class="chart-box"></div></div></div></div>
  <div class="row"><div class="col-lg-4"><div class="card chart-card p-3"><h6>Revenue by Quarter</h6><div id="revenueQuarter" class="chart-box"></div></div></div><div class="col-lg-4"><div class="card chart-card p-3"><h6>New vs Lost Clients</h6><div id="newLost" class="chart-box"></div></div></div><div class="col-lg-4"><div class="card chart-card p-3"><h6>Sales Funnel</h6><div id="salesFunnel" class="chart-box"></div></div></div></div>

  <h4 class="section-title">Client Analytics</h4>
  <div class="row"><div class="col-lg-4"><div class="card chart-card p-3"><h6>Active vs Inactive Clients</h6><div id="clientStatus" class="chart-box"></div></div></div><div class="col-lg-4"><div class="card chart-card p-3"><h6>Client Location Map Data</h6><div id="clientLocation" class="chart-box"></div></div></div><div class="col-lg-4"><div class="card chart-card p-3"><h6>Feature Usage</h6><div id="featureUsage" class="chart-box"></div></div></div></div>
  <div class="alert alert-info">Average Users/Client: <b><%= data.clients.avgUsers %></b> | Average Tasks/Client: <b><%= data.clients.avgTasks %></b> | Average Complaints/Client: <b><%= data.clients.avgComplaints %></b></div>

  <h4 class="section-title">Task Analytics</h4>
  <div class="row"><div class="col-lg-4"><div class="card chart-card p-3"><h6>Task Status Donut</h6><div id="taskStatus" class="chart-box"></div></div></div><div class="col-lg-4"><div class="card chart-card p-3"><h6>Task Priority Matrix</h6><div id="taskPriority" class="chart-box"></div></div></div><div class="col-lg-4"><div class="card chart-card p-3"><h6>Task Completion Trend</h6><div id="taskCompletion" class="chart-box"></div></div></div></div>
  <div class="row"><div class="col-lg-4"><div class="card chart-card p-3"><h6>Department Performance</h6><div id="taskDept" class="chart-box"></div></div></div><div class="col-lg-4"><div class="card chart-card p-3"><h6>Employee Productivity</h6><div id="taskEmployee" class="chart-box"></div></div></div><div class="col-lg-4"><div class="card chart-card p-3"><h6>Task Aging Analysis</h6><div id="taskAging" class="chart-box"></div></div></div></div>
  <div class="alert alert-secondary">Drill-down: Company → Department → Employee → Task Details | Average Resolution Time: <b><%= data.tasks.avgResolutionTime %></b> | Average Completion Time: <b><%= data.tasks.avgCompletionTime %></b></div>

  <h4 class="section-title">Complaint Analytics</h4>
  <div class="row"><div class="col-lg-4"><div class="card chart-card p-3"><h6>Complaints by Floor</h6><div id="complaintsFloor" class="chart-box"></div></div></div><div class="col-lg-4"><div class="card chart-card p-3"><h6>Complaints by Location</h6><div id="complaintsLocation" class="chart-box"></div></div></div><div class="col-lg-4"><div class="card chart-card p-3"><h6>Pending vs Closed</h6><div id="complaintsStatus" class="chart-box"></div></div></div></div>
  <div class="row"><div class="col-lg-6"><div class="card chart-card p-3"><h6>Floor Heatmap</h6><div id="floorHeatmap" class="chart-box"></div></div></div><div class="col-lg-6"><div class="card chart-card p-3"><h6>Root Cause & Escalation Trend</h6><div id="rootCause" class="chart-box"></div></div></div></div>

  <h4 class="section-title">Employee Performance Dashboard</h4>
  <div class="card chart-card p-3"><h6>Leaderboard</h6><div class="table-responsive"><table class="table table-sm"><thead><tr><th>Rank</th><th>Employee</th><th>Department</th><th>Assigned</th><th>Completed</th><th>Pending</th><th>Overdue</th><th>Productivity</th></tr></thead><tbody><% data.employeePerformance.forEach((e,i)=>{ %><tr><td><%= i+1 %></td><td><%= e.name %></td><td><%= e.department %></td><td><%= e.assigned %></td><td><%= e.completed %></td><td><%= e.pending %></td><td><%= e.overdue %></td><td><%= e.productivity %>%</td></tr><% }) %></tbody></table></div></div>

  <h4 class="section-title">Financial Dashboard</h4>
  <div class="row"><div class="col-lg-4"><div class="card chart-card p-3"><h6>Monthly Income</h6><div id="monthlyIncome" class="chart-box"></div></div></div><div class="col-lg-4"><div class="card chart-card p-3"><h6>Paid vs Pending</h6><div id="paidPending" class="chart-box"></div></div></div><div class="col-lg-4"><div class="card chart-card p-3"><h6>Client-wise Revenue</h6><div id="clientRevenue" class="chart-box"></div></div></div></div>
  <div class="alert alert-success">Subscription Revenue: <b>₹<%= data.financial.subscriptionRevenue %></b> | GST Collected: <b>₹<%= data.financial.gstCollected %></b> | Outstanding: <b>₹<%= data.financial.outstanding %></b></div>

  <h4 class="section-title">QR Complaint Analytics</h4>
  <div class="row"><div class="col-lg-4"><div class="card chart-card p-3"><h6>Complaints per QR</h6><div id="complaintsPerQr" class="chart-box"></div></div></div><div class="col-lg-4"><div class="card chart-card p-3"><h6>Most Problematic Locations</h6><div id="problemLocations" class="chart-box"></div></div></div><div class="col-lg-4"><div class="card chart-card p-3"><h6>Device Type</h6><div id="deviceType" class="chart-box"></div></div></div></div>
  <div class="alert alert-warning">QR Scan Count: <b><%= data.qr.scanCount %></b> | Repeat Complaint Locations: <b><%= data.qr.repeatComplaints %></b> | Average Scan Time: <b><%= data.qr.avgScanTime %></b></div>

  <h4 class="section-title">Preventive Maintenance & HR Dashboards</h4>
  <div class="row"><div class="col-lg-6"><div class="card chart-card p-3"><h6>Preventive Maintenance Health</h6><div id="equipmentHealth" class="chart-box"></div></div></div><div class="col-lg-6"><div class="card chart-card p-3"><h6>HR Department-wise</h6><div id="hrDepartment" class="chart-box"></div></div></div></div>
</div>
<script src="https://cdn.jsdelivr.net/npm/echarts@5.5.1/dist/echarts.min.js"></script>
<script>
const BI = <%- JSON.stringify(data) %>;
function pairs(obj){ return Object.entries(obj || {}).map(([name,value])=>({name,value:Number(value)||0})); }
function hasData(obj){ return Object.values(obj || {}).some(value => Number(value) > 0); }
function emptyOption(message='No data available'){
  return {
    xAxis:{show:false}, yAxis:{show:false},
    series:[],
    graphic:[{type:'text',left:'center',top:'middle',style:{text:message,fontSize:15,fill:'#6b7280'}}]
  };
}
function chart(id, option){ const el=document.getElementById(id); if(!el) return; const c=echarts.init(el); c.setOption(option,true); window.addEventListener('resize',()=>c.resize()); }
function bar(id, title, obj){ if(!hasData(obj)) return chart(id,emptyOption()); chart(id,{tooltip:{trigger:'axis'},xAxis:{type:'category',data:Object.keys(obj||{})},yAxis:{type:'value'},series:[{name:title,type:'bar',data:Object.values(obj||{})}]}); }
function line(id, title, obj){ if(!hasData(obj)) return chart(id,emptyOption()); chart(id,{tooltip:{trigger:'axis'},xAxis:{type:'category',data:Object.keys(obj||{})},yAxis:{type:'value'},series:[{name:title,type:'line',smooth:true,areaStyle:{},data:Object.values(obj||{})}]}); }
function donut(id, obj){ if(!hasData(obj)) return chart(id,emptyOption()); chart(id,{tooltip:{trigger:'item'},legend:{bottom:0},series:[{type:'pie',radius:['45%','70%'],data:pairs(obj)}]}); }
function funnel(id, obj){ if(!hasData(obj)) return chart(id,emptyOption()); chart(id,{tooltip:{trigger:'item'},series:[{type:'funnel',data:pairs(obj)}]}); }
line('revenueMonth','Revenue',BI.sales.revenueByMonth); bar('revenueQuarter','Revenue',BI.sales.revenueByQuarter); donut('revenuePlan',BI.sales.revenueByPlan); if(hasData(BI.sales.newClientsByMonth)||hasData(BI.sales.lostClientsByMonth)){ chart('newLost',{tooltip:{trigger:'axis'},legend:{data:['New','Lost']},xAxis:{type:'category',data:Object.keys(BI.sales.newClientsByMonth)},yAxis:{type:'value'},series:[{name:'New',type:'bar',data:Object.values(BI.sales.newClientsByMonth)},{name:'Lost',type:'bar',data:Object.values(BI.sales.lostClientsByMonth)}]}); } else { chart('newLost',emptyOption()); } funnel('salesFunnel',BI.sales.funnel);
donut('clientStatus',BI.clients.activeInactive); bar('clientLocation','Clients',BI.clients.state); donut('featureUsage',BI.clients.featureUsage);
donut('taskStatus',BI.tasks.taskByStatus); bar('taskPriority','Tasks',BI.tasks.taskByPriority); line('taskCompletion','Completed',BI.tasks.taskCompletionTrend); bar('taskDept','Tasks',BI.tasks.taskByDepartment); bar('taskEmployee','Tasks',BI.tasks.taskByEmployee); donut('taskAging',BI.tasks.taskAging);
bar('complaintsFloor','Complaints',BI.complaints.complaintsByFloor); bar('complaintsLocation','Complaints',BI.complaints.complaintsByLocation); donut('complaintsStatus',BI.complaints.complaintsByStatus); bar('floorHeatmap','Hotspots',Object.fromEntries(BI.complaints.floorHeatmap.map(x=>[x.floor,x.count]))); donut('rootCause',BI.complaints.rootCause);
line('monthlyIncome','Income',BI.financial.monthlyIncome); donut('paidPending',BI.financial.paidVsPending); bar('clientRevenue','Revenue',BI.financial.clientWiseRevenue);
bar('complaintsPerQr','Complaints',BI.qr.complaintsPerQr); bar('problemLocations','Complaints',Object.fromEntries(BI.qr.mostProblematicLocations)); donut('deviceType',BI.qr.deviceType);
donut('equipmentHealth',BI.pm.scheduleHealth); bar('hrDepartment','Employees',BI.hr.departmentWise);
function toggleDarkMode(){document.body.classList.toggle('dark-mode');}
function toggleFullScreen(){document.getElementById('analyticsPage').classList.toggle('fullscreen-dashboard');}
</script>
<%- include('../partials/footer') %>
