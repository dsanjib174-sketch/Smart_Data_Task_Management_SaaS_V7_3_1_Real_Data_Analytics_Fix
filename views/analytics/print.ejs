<!doctype html><html><head><meta charset="utf-8"><title><%= title %></title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"><style>@media print{.no-print{display:none}} body{font-size:12px}.kpi{border:1px solid #ddd;padding:12px;border-radius:8px;margin-bottom:10px}</style></head><body class="p-4">
<div class="d-flex justify-content-between"><div><h2>Smart Data Enterprise Analytics Report</h2><p>Generated: <%= new Date().toLocaleString() %></p></div><button class="btn btn-primary no-print" onclick="window.print()">Print / Save PDF</button></div><hr>
<h4>Executive KPI Cards</h4><div class="row"><% Object.entries(data.kpis).forEach(([k,v])=>{ %><div class="col-3"><div class="kpi"><b><%= k %></b><br><span style="font-size:20px"><%= v %></span></div></div><% }) %></div>
<h4>Sales Analytics</h4><table class="table table-bordered"><tbody><% Object.entries(data.sales.revenueByMonth).forEach(([k,v])=>{ %><tr><td>Revenue <%= k %></td><td>₹<%= v %></td></tr><% }) %></tbody></table>
<h4>Task Analytics</h4><table class="table table-bordered"><thead><tr><th>Status</th><th>Count</th></tr></thead><tbody><% Object.entries(data.tasks.taskByStatus).forEach(([k,v])=>{ %><tr><td><%= k %></td><td><%= v %></td></tr><% }) %></tbody></table>
<h4>Complaint Analytics</h4><table class="table table-bordered"><thead><tr><th>Location</th><th>Complaints</th></tr></thead><tbody><% Object.entries(data.complaints.complaintsByLocation).forEach(([k,v])=>{ %><tr><td><%= k %></td><td><%= v %></td></tr><% }) %></tbody></table>
<h4>Employee Leaderboard</h4><table class="table table-bordered"><thead><tr><th>Employee</th><th>Assigned</th><th>Completed</th><th>Overdue</th><th>Productivity</th></tr></thead><tbody><% data.employeePerformance.forEach(e=>{ %><tr><td><%= e.name %></td><td><%= e.assigned %></td><td><%= e.completed %></td><td><%= e.overdue %></td><td><%= e.productivity %>%</td></tr><% }) %></tbody></table>
</body></html>
