<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title || 'Smart Data Task Management' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="manifest" href="/public/manifest.json">
  <meta name="theme-color" content="#111827">
  <link rel="stylesheet" href="/public/css/app.css">
</head>
<body>
<% const isSmartData = currentUser?.role?.scope === 'SMART_DATA'; const clientRole = currentUser?.role?.name || ''; %>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
  <div class="container-fluid">
    <a class="navbar-brand" href="<%= isSmartData ? '/superadmin' : '/client' %>"><%= isSmartData ? 'Smart Data' : (currentUser?.tenant?.companyName || 'Client Portal') %></a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"><span class="navbar-toggler-icon"></span></button>
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav me-auto">
        <% if (isSmartData) { %>
          <li class="nav-item"><a class="nav-link" href="/superadmin">Dashboard</a></li>
          <li class="nav-item"><a class="nav-link" href="/superadmin/users">User Management</a></li>
          <li class="nav-item"><a class="nav-link" href="/superadmin/clients">Clients</a></li>
          <li class="nav-item"><a class="nav-link" href="/superadmin/company">Company Profile</a></li>
          <li class="nav-item"><a class="nav-link" href="/superadmin/plans">Plans</a></li>
          <li class="nav-item"><a class="nav-link" href="/superadmin/internal-tasks">Internal Tasks</a></li>
          <li class="nav-item"><a class="nav-link" href="/analytics">Analytics Center</a></li>
          <li class="nav-item"><a class="nav-link" href="/maintenance">PM Calendar</a></li>
          <li class="nav-item"><a class="nav-link" href="/security">Security</a></li>
          <li class="nav-item"><a class="nav-link" href="/tasks">Client Tasks</a></li>
          <li class="nav-item"><a class="nav-link" href="/qr-locations">QR Locations</a></li>
        <% } else { %>
          <li class="nav-item"><a class="nav-link" href="/client">Dashboard</a></li>
          <li class="nav-item"><a class="nav-link" href="/tasks">Tasks & Kanban</a></li>
          <li class="nav-item"><a class="nav-link" href="/complaints">Complaints</a></li>
          <li class="nav-item"><a class="nav-link" href="/qr-locations">QR Locations</a></li>
          <li class="nav-item"><a class="nav-link" href="/maintenance">PM Calendar</a></li>
          <% if (clientRole === 'CLIENT_ADMIN') { %><li class="nav-item"><a class="nav-link" href="/client/users">User Access</a></li><% } %>
          <li class="nav-item"><a class="nav-link" href="/client/analytics">SLA & KPI Analytics</a></li>
        <% } %>
      </ul>
      <ul class="navbar-nav"><li class="nav-item"><span class="navbar-text me-3"><%= currentUser?.name || '' %></span></li><li class="nav-item"><a class="nav-link" href="/logout">Logout</a></li></ul>
    </div>
  </div>
</nav>
<main class="container-fluid py-4">
